{
  "name": "furever-home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && next build",
    "db:seed": "prisma db seed",
    "dev": "next dev",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "start": "next start",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "playwright test --project=authenticated-admin",
    "test:e2e:all": "playwright test --project=chromium --project=authenticated-admin",
    "test:e2e:auth:headed": "playwright test --project=authenticated-admin --headed",
    "test:e2e:mutations": "PLAYWRIGHT_MUTATION_TESTS=true playwright test --project=authenticated-admin-mutations",
    "test:e2e:mutations:headed": "PLAYWRIGHT_MUTATION_TESTS=true playwright test --project=authenticated-admin-mutations --headed",
    "test": "tsx --test tests/unit/**/*.test.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:unit:watch": "tsx --test --watch tests/unit/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "verify": "npm run prisma:validate && npm run test:unit && npm run lint && npm run typecheck && npm run build",
    "demo:shift-dates": "tsx scripts/shift-demo-dates.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.25.0",
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "echarts": "^6.1.0",
    "framer-motion": "^12.42.0",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.16.3",
    "react": "^19",
    "react-dom": "^19",
    "react-easy-crop": "^6.0.2",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.3"
  }
}
